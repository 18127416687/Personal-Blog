# Required
SECRET_KEY=replace-with-your-secret
SQLALCHEMY_DATABASE_URI=sqlite:///blog.db

# Optional: auto | local | qiniu
UPLOAD_BACKEND=auto

# Optional: required when UPLOAD_BACKEND=qiniu (or auto + configured)
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_DOMAIN=

# Required for AI writing feature
AI_API_KEY=
AI_API_URL=
AI_MODEL=
# Optional: chat_completions | dashscope_generation
AI_API_FORMAT=chat_completions

# Optional for AI image generation (defaults to AI_* where possible)
AI_IMAGE_API_KEY=
AI_IMAGE_API_URL=
AI_IMAGE_MODEL=
AI_IMAGE_SIZE=1024x1024
# Optional: openai_images | dashscope_image_async | dashscope_multimodal
AI_IMAGE_API_FORMAT=openai_images

# Optional for dedicated admin login page (/admin-login)
ADMIN_USERNAME=
ADMIN_PASSWORD=
